# Operations env for deploy tooling (scripts/kindle.sh) and secret rotation.
# Copy to .env and fill in real values. .env is git-ignored — never commit it.
#
# Note: these are separate from worker/.dev.vars, which holds the Worker's local
# dev secrets (MS credentials). TODO_TOKEN must be the SAME in all three places:
# this .env, worker/.dev.vars, and the deployed Cloudflare secret.

# Access token gating the Worker (the Kindle and the page pass it as ?t=...).
# Rotate with:  openssl rand -base64 24 | tr -dc 'A-Za-z0-9'
# then push it:  cd worker && printf '%s' "$TODO_TOKEN" | wrangler secret put TODO_TOKEN
TODO_TOKEN="choose-a-long-random-string"

# --- Kindle device (so you never have to scan the LAN for it again) ---

# The Kindle's LAN IP. Find it once: it runs a Dropbear SSH server on port 22.
#   nmap -p22 --open 192.168.1.0/24        (or check your router's DHCP leases)
KINDLE_IP="192.168.1.44"

# The Kindle's SSH (root) password — the USBNetLite password.
# Set/change it on the device in /mnt/us/usbnetlite/etc/config, then reboot.
KINDLE_SSH_PASS="kindle"
